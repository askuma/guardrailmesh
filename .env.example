# ── API Authentication ─────────────────────────────────────────────────────────
GUARDRAIL_API_KEYS=your-api-key-here,another-key
GUARDRAIL_ADMIN_KEYS=your-admin-key-here
GUARDRAIL_AUTH_ENABLED=true

# ── Database ───────────────────────────────────────────────────────────────────
# Default: SQLite (development)
# GUARDRAIL_DB_URL=sqlite:///guardrail.db
# Production: PostgreSQL
# GUARDRAIL_DB_URL=postgresql://user:pass@localhost/guardrailmesh

# ── NeMo Guardrails ────────────────────────────────────────────────────────────
# LLM provider (first matching key wins):
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com
# OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=sk-ant-...

# ── Lakera Guard ───────────────────────────────────────────────────────────────
LAKERA_GUARD_API_KEY=lkr_...

# ── OpenAI Moderation ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Azure Content Safety & Prompt Shields ──────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://myresource.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=...

# ── AWS Bedrock Guardrails ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_GUARDRAIL_ID=...
AWS_BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Custom HTTP Endpoint ───────────────────────────────────────────────────────
# Connect any internal guardrail API via the built-in generic HTTP adapter.
# GA_GUARD_API_URL=https://your-guardrail.internal.com/check
# GA_GUARD_API_KEY=your-key         # optional
# GA_GUARD_AUTH_HEADER=Authorization
# GA_GUARD_AUTH_PREFIX=Bearer
# GA_GUARD_TEXT_FIELD=text
# GA_GUARD_TIMEOUT_SECS=10

# ── GuardrailsAI ───────────────────────────────────────────────────────────────
# GUARDRAILS_TOKEN=grtt_...   # optional; enables premium hub validators

# ── CORS ───────────────────────────────────────────────────────────────────────
# GUARDRAIL_CORS_ORIGINS=https://your-app.com,https://admin.your-app.com
