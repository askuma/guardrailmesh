# ── API Authentication ─────────────────────────────────────────────────────────
# Required. Comma-separated keys for all API callers (min 32 random chars each).
GUARDRAIL_API_KEYS=your-api-key-here,another-key

# Required. Subset of GUARDRAIL_API_KEYS permitted to call destructive endpoints
# (policy delete, bundle import, rollback). When unset, all API keys are treated
# as admin (backward-compatible, but not recommended for production).
GUARDRAIL_ADMIN_KEYS=your-admin-key-here

# Set to false ONLY for local SQLite development. Raises RuntimeError at startup
# when the database is not SQLite.
GUARDRAIL_AUTH_ENABLED=true

# ── Database ───────────────────────────────────────────────────────────────────
# Default (development only): SQLite
# GUARDRAIL_DB_URL=sqlite:///guardrail.db

# Production: PostgreSQL (required for HA, connection pooling, audit retention)
# GUARDRAIL_DB_URL=postgresql+psycopg2://user:pass@host:5432/guardrailmesh

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Required for consistent cross-replica rate limits in a multi-instance deployment.
# Without this, each replica enforces limits independently (effective limit = N × configured).
# GUARDRAIL_REDIS_URL=rediss://user:pass@redis-host:6380   # rediss:// for TLS

# ── CORS ───────────────────────────────────────────────────────────────────────
# Explicit origin allowlist for browser clients. Default is empty (no CORS).
# Setting * logs a startup warning and should never be used in production.
# GUARDRAIL_CORS_ORIGINS=https://your-app.com,https://admin.your-app.com

# ── Input Size Limit ───────────────────────────────────────────────────────────
# Maximum text characters accepted on /check/* endpoints (default: 32000 ≈ 8k tokens).
# Tune to match your LLM's context window.
# GUARDRAIL_MAX_TEXT_LENGTH=32000

# ── Decision Log Shipping ──────────────────────────────────────────────────────
# Ships guardrail decision events to an append-only HTTP sink (S3 presigned URL,
# Datadog HEC, Splunk, etc.) for durable compliance retention.
# GUARDRAIL_DECISION_LOG_SINK_URL=https://logs.example.com/guardrail/decisions
# GUARDRAIL_DECISION_LOG_AUTH_TOKEN=your-sink-bearer-token

# ── Escalation ─────────────────────────────────────────────────────────────────
# Webhook and email are sent asynchronously (fire-and-forget) and never block
# a guardrail check response.
# GUARDRAIL_ESCALATION_WEBHOOK_URL=https://hooks.example.com/guardrail-alert
# GUARDRAIL_SMTP_HOST=smtp.example.com
# GUARDRAIL_SMTP_PORT=587
# GUARDRAIL_SMTP_USER=alerts@example.com
# GUARDRAIL_SMTP_PASS=...
# GUARDRAIL_SMTP_FROM=guardrail@example.com

# ── NeMo Guardrails ────────────────────────────────────────────────────────────
# LLM provider for NeMo intent classification (first matching key wins):
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com
# OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=sk-ant-...

# ── Lakera Guard ───────────────────────────────────────────────────────────────
# LAKERA_GUARD_API_KEY=lkr_...

# ── OpenAI Moderation ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Azure Content Safety & Prompt Shields ──────────────────────────────────────
# AZURE_CONTENT_SAFETY_ENDPOINT=https://myresource.cognitiveservices.azure.com
# AZURE_CONTENT_SAFETY_KEY=...

# ── AWS Bedrock Guardrails ─────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# AWS_BEDROCK_GUARDRAIL_ID=...
# AWS_BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Custom HTTP Endpoint (CUSTOM backend) ──────────────────────────────────────
# Connect any internal guardrail API via the built-in generic HTTP adapter.
# GA_GUARD_API_URL=https://your-guardrail.internal.com/check
# GA_GUARD_API_KEY=your-key
# GA_GUARD_AUTH_HEADER=Authorization
# GA_GUARD_AUTH_PREFIX=Bearer
# GA_GUARD_TEXT_FIELD=text
# GA_GUARD_TIMEOUT_SECS=10

# ── GuardrailsAI ───────────────────────────────────────────────────────────────
# GUARDRAILS_TOKEN=grtt_...   # optional; enables premium hub validators (ToxicLanguage etc.)
